        document.addEventListener("DOMContentLoaded", function () {
        new Swiper(".category-slider", {
            loop: true,
            autoplay: {
                delay: 3500,
                disableOnInteraction: false
            },
            spaceBetween: 30,
            slidesPerView: 5,      // عدد العناصر التي تظهر في نفس الوقت
            slidesPerGroup: 2,     // عدد العناصر التي تتحرك مع كل dot
            centeredSlides: false,
            breakpoints: {
                0: { slidesPerView: 1, slidesPerGroup: 2 },
                576: { slidesPerView: 2, slidesPerGroup: 2 },
                768: { slidesPerView: 3, slidesPerGroup: 2 },
                1200: { slidesPerView: 5, slidesPerGroup: 2 }
            },
            pagination: {
                el: ".swiper-pagination",
                clickable: true
            }
        });
    });

</script>
