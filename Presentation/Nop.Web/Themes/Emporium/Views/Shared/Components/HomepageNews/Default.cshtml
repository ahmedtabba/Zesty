@model HomepageNewsItemsModel
<style>
    .news-item {
        background: #fff;
        border-radius: 20px!important;
        overflow: hidden;
        box-shadow: 0 0 0 1px rgba(0,0,0,0.04);
        transition: box-shadow .3s ease;

    }

        .news-item:hover {
            box-shadow: 0 6px 20px rgba(0,0,0,0.08);
        }

    .news-image {
        width: 100%;
        height: 220px; /* ثبات الحجم */
        overflow: hidden;
    }

        .news-image img {
            width: 100%;
            height: 100%;
            object-fit: cover; /* أهم سطر */
            display: block;
        }

    .news-content {
        padding: 22px;
        text-align: center;
    }

    .news-date {
        display: block;
        font-size: 12px;
        color: #f28c00;
        letter-spacing: 1px;
        margin-bottom: 8px;
    }

    .news-title {
        display: block;
        font-size: 20px;
        font-weight: 500;
        color: #2c2c2c;
        margin-bottom: 10px;
        text-decoration: none;
    }

    .news-body {
        font-size: 14px;
        color: #777;
        line-height: 1.6;
    }



</style>
@if (Model.NewsItems.Count > 0)
{
    <div class="news-list-homepage">
        <div class="title">
            <strong>@T("News")</strong>
        </div>
        <div class="view-all">
            <a href="@Url.RouteUrl("NewsArchive")">@T("News.ViewAll")</a>
        </div>
        <div class="news-items">
            @foreach (var item in Model.NewsItems)
            {
               
                <div class="news-item">

                    @if (!string.IsNullOrEmpty(item.CoverPictureUrl))
                    {
                        <div class="news-image">
                            <img src="@item.CoverPictureUrl" alt="@item.Title" />
                        </div>
                    }

                    <div class="news-content">
                        <span class="news-date">
                            @item.CreatedOn.ToString("dd MMM yyyy")
                        </span>

                        <a class="news-title"
                           href="@Url.RouteUrl("NewsItem", new { SeName = item.SeName })">
                            @item.Title
                        </a>

                        <div class="news-body">
                            @Html.Raw(item.Short)
                        </div>
                    </div>
                </div>


            }
        </div>
    </div>

}