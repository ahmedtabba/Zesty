@model HomepageNewsItemsModel
<style>
   
</style>
@if (Model.NewsItems.Count > 0)
{
    <div class="news-list-homepage">
        <div class="title">
            <strong>@T("News")</strong>
        </div>
        <div class="view-all">
            <a href="@Url.RouteUrl("NewsArchive")">@T("News.ViewAll")</a>
        </div>
        <div class="news-items">
            @foreach (var item in Model.NewsItems)
            {
               
                <div class="news-item">

                    @if (!string.IsNullOrEmpty(item.CoverPictureUrl))
                    {
                        <div class="news-image">
                            <img src="@item.CoverPictureUrl" alt="@item.Title" />
                        </div>
                    }

                    <div class="news-content">
                        <span class="news-date">
                            @item.CreatedOn.ToString("dd MMM yyyy")
                        </span>

                        <a class="news-title"
                           href="@Url.RouteUrl("NewsItem", new { SeName = item.SeName })">
                            @item.Title
                        </a>

                        <div class="news-body">
                            @Html.Raw(item.Short)
                        </div>
                    </div>
                </div>


            }
        </div>
    </div>

}