@model Nop.Plugin.Misc.ProductLabels.Models.PublicInfoModel

@if (Model.Labels != null && Model.Labels.Any())
{
    <div class="product-labels">
        @foreach (var label in Model.Labels)
        {
            <span class="badge bg-success" style="margin-right:5px;">
                @label.LabelText
            </span>
        }
    </div>
}