@model TestimonialItemModel

@{
    //page title
    ViewBag.PageTitle = T("Plugins.Widgets.Testimonial.Edit").Text;
    //active menu item (system name)
    NopHtml.SetActiveMenuItemSystemName("Widgets.Testimonial.List");
}

<form asp-controller="WidgetsTestimonial" asp-action="Edit" method="post">
    <div class="content-header clearfix">
        <h1 class="float-left">
            @T("Plugins.Widgets.Testimonial.Edit") - @Model.Name
            <small>
                <i class="fas fa-arrow-circle-left"></i>
                <a asp-action="List">@T("Plugins.Widgets.Testimonial.BackToList")</a>
            </small>
        </h1>
        <div class="float-right">
            <button type="submit" name="save" class="btn btn-primary">
                <i class="far fa-save"></i>
                @T("Admin.Common.Save")
            </button>
            <button type="submit" name="save-continue" class="btn btn-primary">
                <i class="far fa-save"></i>
                @T("Admin.Common.SaveContinue")
            </button>
            <span id="testimonial-delete" class="btn btn-danger">
                <i class="far fa-trash-alt"></i>
                @T("Admin.Common.Delete")
            </span>
        </div>
    </div>
    @await Html.PartialAsync("~/Plugins/Widgets.Testimonial/Areas/Admin/Views/WidgetsTestimonial/_CreateOrUpdate.cshtml", Model)
</form>
<nop-delete-confirmation asp-model-id="@Model.Id" asp-button-id="testimonial-delete" />